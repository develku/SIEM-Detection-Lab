# =============================================================================
# SIEM Detection Lab — Environment Variables
# =============================================================================
#
# Copy this file to .env and change the password:
#   cp .env.example .env
#
# Docker Compose automatically reads .env files in the same directory.
# The .env file is in .gitignore — your password won't be committed to git.
# =============================================================================

# Splunk admin password (minimum 8 characters)
SPLUNK_PASSWORD=ChangeMeNow123!
